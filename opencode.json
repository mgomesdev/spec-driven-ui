{
   "$schema": "https://opencode.ai/config.json",
   "server": {
      "port": 4096,
      "hostname": "0.0.0.0",
      "mdns": true,
      "cors": ["http://localhost:5173"]
   },
   "tools": {
      "write": false,
      "bash": false
   },
   "autoupdate": "notify",
   "permission": {
      "edit": "ask",
      "bash": "ask"
   },
   "compaction": {
      "auto": true,
      "prune": true,
      "reserved": 10000
   },
   "watcher": {
      "ignore": ["node_modules/**", "dist/**", ".git/**", "trash/**", "readme/**"]
   },
   "instructions": ["specs/docs/*.md"],
   "disabled_providers": [],
   "enabled_providers": ["big-pickle"],
   "share": "disabled"
}
